{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Permissions for the PM/UX contrib kit. Branches are derived per-contributor by the skill (from `git config user.name`), so we allow broad git operations and rely on the explicit deny list to block pushes to {{MAIN_BRANCH}} and other dangerous actions.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git config user.name)",
      "Bash(git config user.name:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-remote:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git add :*)",
      "Bash(git add -A)",
      "Bash(git add .)",
      "Bash(git commit -m :*)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh repo view:*)",
      "Bash(ls:*)",
      "Bash(cat :*)",
      "Bash(pwd)",
      "Bash(find :*)",
      "Bash(grep :*)"
    ],
    "deny": [
      "Bash(git push origin {{MAIN_BRANCH}}:*)",
      "Bash(git push origin {{MAIN_BRANCH}})",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -d:*)",
      "Bash(git checkout {{MAIN_BRANCH}})",
      "Bash(gh pr merge:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Edit(.npmrc)",
      "Edit(.gitignore)",
      "Edit(.github/CODEOWNERS)",
      "Edit(README.md)",
      "Edit(CONTRIBUTING.md)",
      "Edit(package.json)",
      "Edit(mock-data/**)",
      "Edit(.claude/**)",
      "Edit(tests/**)",
      "Write(.npmrc)",
      "Write(.gitignore)",
      "Write(.github/CODEOWNERS)",
      "Write(.claude/settings.json)",
      "Write(README.md)",
      "Write(CONTRIBUTING.md)",
      "Write(package.json)",
      "Write(mock-data/**)",
      "Write(.claude/**)",
      "Write(tests/**)"
    ]
  }
}
